# Prompt Service Environment
# Copy to .env and fill in values. Never commit .env or credentials.

# Port (default 5002 - different from auth-service 5001)
PORT=5002

# CORS - comma-separated for multiple origins
CORS_ORIGIN=http://localhost:3000

# MongoDB (can share same DB as auth-service)
MONGODB_URI=mongodb://localhost:27017/prompt-library

# GOOGLE_APPLICATION_CREDENTIALS=./googleServiceAccount.json

# RabbitMQ (for domain events)
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE=domain.events
