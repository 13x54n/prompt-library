# Notification Service Environment
# Copy to .env and fill in values. Never commit .env or credentials.

# Port (default 5003)
PORT=5003

# CORS - comma-separated for multiple origins
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/prompt-library

# Firebase Admin credentials (path to JSON file or raw JSON string)
# GOOGLE_APPLICATION_CREDENTIALS=./googleServiceAccount.json

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE=domain.events
RABBITMQ_QUEUE=notifications.events
RABBITMQ_RETRY_QUEUE=notifications.events.retry
RABBITMQ_DLQ=notifications.events.dlq
RABBITMQ_ROUTING_KEY=#
RABBITMQ_MAX_RETRIES=5
RABBITMQ_RETRY_DELAY_MS=5000
