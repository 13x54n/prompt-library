# Auth Service Environment
# Copy to .env and fill in values. Never commit .env or credentials.

# Port
PORT=5001

# CORS - comma-separated for multiple origins
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/prompt-library

# Firebase Admin - ONE of these (required for auth):
# Option A: Path to service account JSON (copy googleServiceAccount.json.example, add real keys, NEVER commit)
# GOOGLE_APPLICATION_CREDENTIALS=./googleServiceAccount.json
# Option B: Raw JSON string (for CI/deploy - no file)
# GOOGLE_APPLICATION_CREDENTIALS={"type":"service_account","project_id":"..."}
